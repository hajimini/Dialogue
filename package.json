{
  "name": "ai-companion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-next.mjs",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:memory": "jest src/lib/memory/__tests__",
    "test:memory:performance": "npx tsx scripts/run-memory-performance.ts",
    "report:evaluations": "node scripts/evaluation-report.mjs",
    "prepare:batch-cases": "node scripts/prompt-regression.mjs",
    "test:embedding": "node scripts/test-embedding.mjs",
    "test:batch": "node --experimental-strip-types tests/batch-tester.ts",
    "test:auto-eval": "node --experimental-strip-types tests/auto-evaluator.ts",
    "test:prompt-compare": "node --experimental-strip-types tests/prompt-comparator.ts",
    "test:regression": "ts-node tests/regression.ts",
    "test:memory:cache": "npx tsx scripts/validate-memory-cache.ts",
    "test:memory:access": "npx tsx scripts/test-memory-access-control.ts",
    "test:memory:e2e": "npx tsx scripts/run-memory-frontend-e2e.ts",
    "test:memory:schema": "node scripts/verify-memory-frontend-schema.mjs",
    "test:compare": "node scripts/run-comparison-test.mjs",
    "test:migration": "node scripts/test-migration.mjs",
    "test:rollback": "node scripts/test-rollback.mjs",
    "db:check": "node scripts/verify-postgres-connection.mjs",
    "test:nvidia": "node scripts/test-nvidia-embedding.mjs",
    "test:nvidia:integration": "node scripts/test-nvidia-integration.mjs",
    "test:nvidia:simple": "node scripts/test-nvidia-simple.mjs",
    "migrate:mem0": "npx tsx scripts/migrate-to-mem0.ts",
    "rollback:mem0": "npx tsx scripts/rollback-migration.ts",
    "rollback:mem0:latest": "npx tsx scripts/rollback-migration.ts --latest",
    "rollback:mem0:clear": "npx tsx scripts/rollback-migration.ts --latest --clear-supabase"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@base-ui/react": "^1.3.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.7.0",
    "mem0ai": "^2.4.3",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jest": "^30.3.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  }
}
