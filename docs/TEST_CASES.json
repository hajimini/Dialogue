{
  "version": 1,
  "source_files": [
    "docs/TEST_CASES.md",
    "../docs/PHASE7_POLISHING_GUIDE.md"
  ],
  "hard_rules": {
    "max_reply_length": 300,
    "blacklist_phrases": [
      "作为AI",
      "作为一个AI",
      "身为AI",
      "我是AI",
      "这是一个好问题",
      "如果你需要帮助",
      "这是我应该做的",
      "有什么可以帮你"
    ],
    "blacklist_regexes": [
      "^(当然|好的|没问题)[，,:：]",
      "(^|\\n)首先[，,:：]?",
      "(^|\\n)总之[，,:：]?",
      "我理解(?:你的|你现在的)?感受"
    ],
    "markdown_regexes": [
      "\\*\\*",
      "(?<!\\*)\\*(?!\\*)",
      "(^|\\n)#{1,6}\\s",
      "```",
      "`[^`]+`"
    ],
    "list_numbering_regexes": [
      "(^|\\n)\\s*\\d+\\.\\s+"
    ],
    "ai_identity_phrases": [
      "作为AI",
      "作为一个AI",
      "身为AI",
      "我是AI"
    ]
  },
  "quality_checks": [
    {
      "id": "E01",
      "category": "E",
      "title": "10轮日常聊天平均长度",
      "expectation": "日常闲聊平均回复应在 20-80 字之间，不应长期超过 100 字。",
      "source": "../docs/PHASE7_POLISHING_GUIDE.md"
    },
    {
      "id": "E02",
      "category": "E",
      "title": "10轮长度波动",
      "expectation": "回复长度应有自然波动，不能每条都差不多长。",
      "source": "../docs/PHASE7_POLISHING_GUIDE.md"
    },
    {
      "id": "E03",
      "category": "E",
      "title": "无列表与分点",
      "expectation": "10 轮回复中不应出现 1. 2. 3.、分点或标题。",
      "source": "../docs/PHASE7_POLISHING_GUIDE.md"
    },
    {
      "id": "E04",
      "category": "E",
      "title": "无 AI 套话",
      "expectation": "避免“我理解”“首先”“总之”“这是一个好问题”“如果你需要帮助”等套路化表达。",
      "source": "../docs/PHASE7_POLISHING_GUIDE.md"
    },
    {
      "id": "E05",
      "category": "E",
      "title": "emoji 使用克制",
      "expectation": "emoji 只在符合人设时偶尔使用，通常更适合用口语文字表达情绪。",
      "source": "../docs/PHASE7_POLISHING_GUIDE.md"
    },
    {
      "id": "E06",
      "category": "E",
      "title": "口癖一致但不过度",
      "expectation": "人设口癖要真实用到，但不能句句都用。",
      "source": "../docs/PHASE7_POLISHING_GUIDE.md"
    },
    {
      "id": "E07",
      "category": "E",
      "title": "无 Markdown",
      "expectation": "回复中不应出现加粗、斜体、代码块或其他 Markdown 格式。",
      "source": "../docs/PHASE7_POLISHING_GUIDE.md"
    },
    {
      "id": "E08",
      "category": "E",
      "title": "深话题仍需克制",
      "expectation": "即使是深度问题，也不应写成长篇小作文。",
      "source": "../docs/PHASE7_POLISHING_GUIDE.md"
    }
  ],
