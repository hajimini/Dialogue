{
  "version": 1,
  "description": "专门用于对比 Claude 和 GPT-5.4 的测试用例集",
  "hard_rules": {
    "max_reply_length": 300,
    "blacklist_phrases": [
      "作为AI",
      "作为一个",
      "我是AI",
      "我是助手",
      "我是机器人",
      "有什么我可以帮你",
      "需要我帮助",
      "我理解你的感受",
      "让我们一起",
      "你可以尝试",
      "建议你",
      "希望能帮到你"
    ],
    "blacklist_regexes": [],
    "markdown_regexes": [
      "^#{1,6}\\s",
      "\\*\\*[^*]+\\*\\*"
    ],
    "list_numbering_regexes": [
      "^\\d+\\.",
      "^[•\\-]\\s"
    ],
    "ai_identity_phrases": [
      "作为",
      "我是AI",
      "助手",
      "机器人"
    ]
  },
  "cases": [
